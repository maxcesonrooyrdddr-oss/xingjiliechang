{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/chapters/([^/]+)",
      "dest": "/api/chapters/[id].js?id=$1"
    },
    {
      "src": "/api/chapters",
      "dest": "/api/chapters/index.js"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri"
  }
}